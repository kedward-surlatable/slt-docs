          <mxGeometry x="370" y="598" width="20" height="18" as="geometry" />
        </mxCell>
        <mxCell id="legendYellowText" value="Decision point" style="text;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="395" y="598" width="100" height="20" as="geometry" />
