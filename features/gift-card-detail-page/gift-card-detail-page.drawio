        </mxCell>

        <!-- Key Insight Box -->
        <mxCell id="insight" value="KEY INSIGHT (SLTBE-7888): Google indexes the master SKU (876953) via the canonical tag,&#xa;but site navigation always uses variant SKUs (5940804). Without SSR redirect, direct loads&#xa;from Google hit the master SKU URL which the client-side SFCC session cannot resolve." style="shape=note;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;size=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="670" width="920" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
