<mxfile host="app.diagrams.net" modified="2026-03-02T00:00:00.000Z" agent="Claude" version="24.0.0" type="device">
  <diagram id="gdp-ssr-flow" name="GDP SSR Data Flow &amp; Master SKU Redirect">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title1" value="GDP Architecture &amp; SSR Data Flow (SLTBE-7888 Fix)" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="700" height="30" as="geometry" />
        </mxCell>

        <!-- Step 1: Browser Request -->
        <mxCell id="step1" value="1. Browser Request&#xa;/product/traditional-gift-card/876953&#xa;(Master SKU from Google)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- Step 2: SSR getProps -->
        <mxCell id="step2" value="2. SSR getProps()&#xa;Server-side (Node.js)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow 1→2 -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="step1" target="step2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: Validate SKU -->
        <mxCell id="step3" value="3. isValidSKU(params.sku)&#xa;Reject empty/invalid" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="560" y="70" width="160" height="90" as="geometry" />
        </mxCell>

        <!-- Arrow 2→3 -->
        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="step2" target="step3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3 fail -->
        <mxCell id="step3fail" value="Return {}&#xa;(client fallback)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="780" y="70" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow 3→fail -->
        <mxCell id="arrow3fail" value="invalid" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="step3" target="step3fail" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 4: ssrBffGet -->
        <mxCell id="step4" value="4. ssrBffGet('/products/876953')&#xa;Server-side SLAS auth&#xa;Cache-Control: no-store" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="210" width="230" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow 3→4 -->
        <mxCell id="arrow3" value="valid" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="step3" target="step4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 5: URL Comparison -->
        <mxCell id="step5" value="5. Compare URLs&#xa;req.url path vs product.c_pwaUrl&#xa;&#xa;/traditional-gift-card/876953&#xa;  vs /traditional-gift-card/5940804" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="195" width="240" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow 4→5 -->
        <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="step4" target="step5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 6a: Redirect -->
        <mxCell id="step6a" value="6a. HTTP 301 Redirect&#xa;→ /product/traditional-gift-card/5940804&#xa;(Google re-indexes variant URL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="700" y="195" width="260" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow 5→6a -->
        <mxCell id="arrow5a" value="mismatch&#xa;(master SKU)" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="step5" target="step6a" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 6b: Return Product -->
        <mxCell id="step6b" value="6b. configHtmlCache(res)&#xa;return { product }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="350" width="230" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow 5→6b -->
        <mxCell id="arrow5b" value="match&#xa;(variant SKU)" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="step5" target="step6b" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 7: SSRProductProvider -->
        <mxCell id="step7" value="7. SSRProductProvider&#xa;Passes product to React context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="350" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow 6b→7 -->
        <mxCell id="arrow6b" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="step6b" target="step7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 8: PdpProvider + useProduct -->
        <mxCell id="step8" value="8. PdpProvider → useProduct(sku)&#xa;Reads SSR product as initialData&#xa;isLoading = false immediately" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="660" y="350" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow 7→8 -->
        <mxCell id="arrow7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="step7" target="step8" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 9: BuyBox Renders -->
        <mxCell id="step9" value="9. GiftCardBuyBox Renders&#xa;Amount chips, form fields,&#xa;Add to Bag button visible" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="460" width="280" height="70" as="geometry" />
        </mxCell>

        <!-- Arrow 8→9 -->
        <mxCell id="arrow8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="step8" target="step9" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Redirect loop back -->
        <mxCell id="arrowRedirect" value="Browser follows redirect,&#xa;re-enters at step 1 with variant SKU" style="edgeStyle=orthogonalEdgeStyle;dashed=1;fontSize=9;strokeColor=#9673a6;" edge="1" source="step6a" target="step1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="960" y="160" />
              <mxPoint x="960" y="60" />
              <mxPoint x="150" y="60" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="570" width="920" height="80" as="geometry" />
        </mxCell>
        <mxCell id="legendTitle" value="Legend" style="text;html=1;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="50" y="575" width="80" height="20" as="geometry" />
